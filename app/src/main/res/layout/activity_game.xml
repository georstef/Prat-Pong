<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- TOP ROW: Name 1 · Swap · Name 2 -->
    <LinearLayout
        android:id="@+id/topRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTeam1Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PLAYER 1"
            android:textColor="#FFFFFF"
            android:textSize="22dp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/name_border"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSwap"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="⇄"
            android:textColor="#FF8F00"
            android:textSize="26dp"
            android:gravity="center"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tvTeam2Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PLAYER 2"
            android:textColor="#FFFFFF"
            android:textSize="22dp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/name_border"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- SERVE DOTS ROW -->
    <LinearLayout
        android:id="@+id/dotsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        app:layout_constraintTop_toBottomOf="@id/topRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/dotServer1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="2dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/dot1a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textSize="20dp"
                android:textColor="#4CAF50"
                android:alpha="0.2"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/dot1b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textSize="20dp"
                android:textColor="#4CAF50"
                android:alpha="0.2"/>

        </LinearLayout>

        <View
            android:layout_width="200dp"
            android:layout_height="1dp"/>

        <LinearLayout
            android:id="@+id/dotServer2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="2dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/dot2a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textSize="20dp"
                android:textColor="#4CAF50"
                android:alpha="0.2"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/dot2b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textSize="20dp"
                android:textColor="#4CAF50"
                android:alpha="0.2"/>

        </LinearLayout>

    </LinearLayout>

    <!-- MIDDLE ROW: Score 1 · Sets info · Score 2 -->
    <LinearLayout
        android:id="@+id/middleRow"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/dotsRow"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvScore1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="40dp"
            app:autoSizeMaxTextSize="200dp"
            app:autoSizeStepGranularity="1dp"/>

        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvSetsScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 — 0"
                android:textColor="#FFFFFF"
                android:textSize="26dp"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvMatchFormat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="B1 · 11"
                android:textColor="#FF8F00"
                android:textSize="11dp"
                android:letterSpacing="0.1"
                android:alpha="0.7"
                android:gravity="center"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvScore2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="40dp"
            app:autoSizeMaxTextSize="200dp"
            app:autoSizeStepGranularity="1dp"/>

    </LinearLayout>

    <!-- Mic status indicator — floats above bottom bar, does not affect layout -->
    <TextView
        android:id="@+id/tvMicIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎙️"
        android:textSize="18dp"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: NEW SET · RESTART · SETUP -->
        <LinearLayout
            android:id="@+id/bottomControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="0dp">

            <TextView
                android:id="@+id/btnNewGame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW SET"
                android:textColor="#FFFFFF"
                android:textSize="10dp"
                android:letterSpacing="0.1"
                android:alpha="0.35"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="6dp"
                android:paddingBottom="0dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="·"
                android:textColor="#FFFFFF"
                android:alpha="0.2"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/btnRestart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESTART"
                android:textColor="#FFFFFF"
                android:textSize="10dp"
                android:letterSpacing="0.1"
                android:alpha="0.35"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="6dp"
                android:paddingBottom="0dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="·"
                android:textColor="#FFFFFF"
                android:alpha="0.2"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/btnSetup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETUP"
                android:textColor="#FFFFFF"
                android:textSize="10dp"
                android:letterSpacing="0.1"
                android:alpha="0.35"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="6dp"
                android:paddingBottom="0dp"/>

        </LinearLayout>

        <!-- Row 2: −1 · ⓘ · −1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="6dp"
            android:paddingBottom="0dp">

            <TextView
                android:id="@+id/btnUndo1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="−1"
                android:textColor="#FF8F00"
                android:textSize="16dp"
                android:fontFamily="sans-serif-light"
                android:alpha="0.5"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="0dp"
                android:paddingBottom="6dp"/>

            <TextView
                android:id="@+id/btnInfo"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="ⓘ"
                android:textColor="#FF8F00"
                android:textSize="18dp"
                android:alpha="0.7"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="0dp"
                android:paddingBottom="6dp"/>

            <TextView
                android:id="@+id/btnUndo2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="−1"
                android:textColor="#FF8F00"
                android:textSize="16dp"
                android:fontFamily="sans-serif-light"
                android:alpha="0.5"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="0dp"
                android:paddingBottom="6dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>